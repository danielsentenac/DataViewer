# Copy this file to `scripts/dataviewer.local.env` and edit it for your
# private deployment. That file is gitignored.

# Used by `./scripts/flutter_local.sh`.
DATAVIEWER_BASE_URL=http://your-private-tomcat-host:8081/dataviewer

# Used by `./scripts/sanitize_public_repo.sh --restore`.
DATAVIEWER_ZCM_SUB_ENDPOINT=tcp://your-private-zcm-host:3333
DATAVIEWER_PRIVATE_HOST_ALIAS=your-private-host
DATAVIEWER_PRIVATE_HOST_FQDN=your-private-host.example.org
